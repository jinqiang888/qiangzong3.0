# Auto-generated
openclaw.json
openclaw.json.bak
gateway.cmd

# Large binaries
*.exe
*.dll
*.node

# Sensitive files - exclude from backup
*.jsonl
*.env
*.env.*
.DS_Store
Thumbs.db

# OpenClaw temporary files
*.tmp
*.temp
*~

# Agent session files that may contain secrets
.openclaw-backup/agents/*/sessions/
agents/*/sessions/
